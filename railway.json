{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "medvault-backend/Dockerfile"
    },
    "deploy": {
        "startCommand": "cd medvault-backend && java -jar target/*.jar",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}